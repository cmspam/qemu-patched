+/*
+ * Copyright 2025 Google LLC
+ * SPDX-License-Identifier: MIT
+ */
+
+#ifndef XE_RENDERER_OBJECT_H_
+#define XE_RENDERER_OBJECT_H_
+
+#include "xe_renderer.h"
+
+/**
+ * struct xe_object - host-side wrapper around a Xe GEM buffer object.
+ *
+ * Extends drm_object with the CPU caching / map_info needed to tell
+ * the virtio-gpu blob layer how the guest should map the buffer.
+ */
+struct xe_object {
+   struct drm_object base;
+
+   /**
+    * @map_info: VIRGL_RENDERER_MAP_CACHE_* constant derived from the
+    * cpu_caching field supplied at GEM create time:
+    *   DRM_XE_GEM_CPU_CACHING_WB → VIRGL_RENDERER_MAP_CACHE_CACHED
+    *   DRM_XE_GEM_CPU_CACHING_WC → VIRGL_RENDERER_MAP_CACHE_WC
+    */
+   int map_info;
+};
+DEFINE_CAST(drm_object, xe_object)
+
+struct xe_object *xe_object_create(uint32_t handle, uint64_t size,
+                                   uint16_t cpu_caching);
+
+void xe_renderer_free_object(struct drm_context *dctx,
+                             struct drm_object *dobj);
+
+#endif /* XE_RENDERER_OBJECT_H_ */
--- a/src/drm/xe/xe_object.c	2026-04-01 00:29:31.497961298 +0000
+++ b/src/drm/xe/xe_object.c	2026-03-31 18:36:42.000000000 +0000
@@ -0,0 +1,43 @@
+/*
+ * Copyright 2025 Google LLC
+ * SPDX-License-Identifier: MIT
+ */
+
+#include "xe_ccmd.h"
+#include "xe_object.h"
+#include "xe_resource.h"
+
+struct xe_object *
+xe_object_create(uint32_t handle, uint64_t size, uint16_t cpu_caching)
+{
+   struct xe_object *obj = calloc(1, sizeof(*obj));
+   if (!obj)
+      return NULL;
+
+   obj->base.handle = handle;
+   obj->base.size   = size;
+
+   switch (cpu_caching) {
+   case DRM_XE_GEM_CPU_CACHING_WC:
+      obj->map_info = VIRGL_RENDERER_MAP_CACHE_WC;
+      break;
+   case DRM_XE_GEM_CPU_CACHING_WB:
+   default:
+      obj->map_info = VIRGL_RENDERER_MAP_CACHE_CACHED;
+      break;
+   }
+
+   return obj;
+}
+
+void
+xe_renderer_free_object(struct drm_context *dctx, struct drm_object *dobj)
+{
+   struct drm_gem_close close = {
+      .handle = dobj->handle,
+   };
+
+   xe_ioctl(dctx->fd, DRM_IOCTL_GEM_CLOSE, &close);
+
+   free(dobj);
+}

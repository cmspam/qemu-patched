@@ -0,0 +1,275 @@
+/*
+ * Copyright 2025 Google LLC
+ * SPDX-License-Identifier: MIT
+ *
+ * xe_proto.h — shared protocol between the guest Mesa Xe virtio driver
+ * and the virglrenderer host-side Xe native context.
+ *
+ * All structs must be:
+ *  - A multiple of 8 bytes in size
+ *  - Aligned to at most 8 bytes
+ * This is enforced by XE_STATIC_ASSERT_SIZE().
+ */
+
+#ifndef XE_VIRTIO_PROTO_H_
+#define XE_VIRTIO_PROTO_H_
+
+
+
+#ifdef __GNUC__
+#  pragma GCC diagnostic push
+#  pragma GCC diagnostic error "-Wpadded"
+#endif
+
+#define XE_STATIC_ASSERT_SIZE(t)                                              \
+   static_assert(sizeof(struct t) % 8 == 0,                                  \
+                 "sizeof(struct " #t ") not multiple of 8");                  \
+   static_assert(alignof(struct t) <= 8,                                      \
+                 "alignof(struct " #t ") too large");
+
+#define XE_DEFINE_CAST(parent, child)                                         \
+   XE_STATIC_ASSERT_SIZE(child)                                               \
+   DEFINE_CAST(parent, child)
+
+/* -------------------------------------------------------------------------
+ * Command opcodes
+ * ------------------------------------------------------------------------- */
+
+enum xe_ccmd {
+   XE_CCMD_NOP              = 0,  /* unused; opcodes start at 1 */
+   XE_CCMD_DEVICE_QUERY     = 1,  /* DRM_IOCTL_XE_DEVICE_QUERY          */
+   XE_CCMD_GEM_CREATE       = 2,  /* DRM_IOCTL_XE_GEM_CREATE             */
+   XE_CCMD_VM_CREATE        = 3,  /* DRM_IOCTL_XE_VM_CREATE              */
+   XE_CCMD_VM_DESTROY       = 4,  /* DRM_IOCTL_XE_VM_DESTROY             */
+   XE_CCMD_VM_BIND          = 5,  /* DRM_IOCTL_XE_VM_BIND                */
+   XE_CCMD_EXEC_QUEUE_CREATE  = 6, /* DRM_IOCTL_XE_EXEC_QUEUE_CREATE     */
+   XE_CCMD_EXEC_QUEUE_DESTROY = 7, /* DRM_IOCTL_XE_EXEC_QUEUE_DESTROY    */
+   XE_CCMD_EXEC             = 8,  /* DRM_IOCTL_XE_EXEC                   */
+};
+
+#define XE_CCMD(_cmd, _len) (struct vdrm_ccmd_req){  \
+      .cmd = XE_CCMD_##_cmd,                          \
+      .len = (_len),                                  \
+   }
+
+/* -------------------------------------------------------------------------
+ * Shmem layout (host → guest shared memory)
+ * ------------------------------------------------------------------------- */
+
+/**
+ * struct xe_shmem - layout of the shmem blob used for host→guest comms.
+ *
+ * Placed at the start of the blob returned by get_blob(blob_id=0).
+ * The response ring starts at offset shmem->base.rsp_mem_offset.
+ */
+struct xe_shmem {
+   struct vdrm_shmem base;
+
+   /**
+    * @error_mask: bitmask of exec_queue_ids that have been banned by
+    * the kernel.  Bit N set means exec_queue_id N is banned.
+    * Updated atomically by the host; polled by the guest.
+    * Limited to the first 64 exec queue ids for simplicity.
+    */
+   uint64_t banned_exec_queue_mask;
+};
+DEFINE_CAST(vdrm_shmem, xe_shmem)
+
+/* -------------------------------------------------------------------------
+ * XE_CCMD_DEVICE_QUERY
+ *
+ * Proxies DRM_IOCTL_XE_DEVICE_QUERY to the host.  Two-phase like the
+ * kernel ioctl: first call with size=0 to get required size, second with
+ * the full size to retrieve data.
+ * ------------------------------------------------------------------------- */
+
+struct xe_ccmd_device_query_req {
+   struct vdrm_ccmd_req hdr;
+
+   uint32_t query;   /* DRM_XE_DEVICE_QUERY_* */
+   uint32_t size;    /* requested payload size (0 = probe) */
+};
+XE_DEFINE_CAST(vdrm_ccmd_req, xe_ccmd_device_query_req)
+
+struct xe_ccmd_device_query_rsp {
+   struct vdrm_ccmd_rsp hdr;
+
+   uint32_t pad;
+   int32_t  ret;      /* errno on failure, 0 on success */
+   uint32_t size;     /* actual payload size written */
+   uint8_t  payload[]; /* query data (variable length, padded to 8B) */
+};
+XE_STATIC_ASSERT_SIZE(xe_ccmd_device_query_rsp)
+
+/* -------------------------------------------------------------------------
+ * XE_CCMD_GEM_CREATE
+ *
+ * Creates a GEM BO on the host and associates it with blob_id so that
+ * get_blob() can later retrieve a virgl resource handle for it.
+ * No response is needed; errors are surfaced through get_blob().
+ * ------------------------------------------------------------------------- */
+
+struct xe_ccmd_gem_create_req {
+   struct vdrm_ccmd_req hdr;
+
+   uint64_t size;        /* BO size in bytes                             */
+   uint32_t placement;   /* memory placement bitmask                     */
+   uint32_t flags;       /* DRM_XE_GEM_CREATE_FLAG_*                     */
+   uint32_t vm_id;       /* attached VM id (0 = not attached)            */
+   uint32_t blob_id;     /* guest-assigned blob id for get_blob()        */
+   uint16_t cpu_caching; /* DRM_XE_GEM_CPU_CACHING_{WB,WC}              */
+   uint16_t pad[3];
+};
+XE_DEFINE_CAST(vdrm_ccmd_req, xe_ccmd_gem_create_req)
+
+/* -------------------------------------------------------------------------
+ * XE_CCMD_VM_CREATE
+ * ------------------------------------------------------------------------- */
+
+struct xe_ccmd_vm_create_req {
+   struct vdrm_ccmd_req hdr;
+
+   uint32_t flags;   /* DRM_XE_VM_CREATE_FLAG_* */
+   uint32_t pad;
+};
+XE_DEFINE_CAST(vdrm_ccmd_req, xe_ccmd_vm_create_req)
+
+struct xe_ccmd_vm_create_rsp {
+   struct vdrm_ccmd_rsp hdr;
+
+   uint32_t pad;
+   int32_t  ret;
+   uint32_t vm_id;   /* host-assigned VM id */
+};
+XE_STATIC_ASSERT_SIZE(xe_ccmd_vm_create_rsp)
+
+/* -------------------------------------------------------------------------
+ * XE_CCMD_VM_DESTROY
+ * ------------------------------------------------------------------------- */
+
+struct xe_ccmd_vm_destroy_req {
+   struct vdrm_ccmd_req hdr;
+
+   uint32_t vm_id;
+   uint32_t pad;
+};
+XE_DEFINE_CAST(vdrm_ccmd_req, xe_ccmd_vm_destroy_req)
+
+/* -------------------------------------------------------------------------
+ * XE_CCMD_VM_BIND
+ *
+ * Each bind operation is serialised inline after the request header.
+ * The guest uses res_id in place of the GEM handle; the host translates.
+ * Bind is synchronous: the host processes all ops before returning seqno.
+ * ------------------------------------------------------------------------- */
+
+/**
+ * struct xe_ccmd_vm_bind_op - one bind/unbind operation (guest wire format).
+ *
+ * Mirrors drm_xe_vm_bind_op but replaces @obj (gem handle) with @res_id
+ * (virgl resource id) so the host can translate.  For UNMAP and UNMAP_ALL
+ * ops @res_id is zero.
+ */
+struct xe_ccmd_vm_bind_op {
+   uint32_t res_id;      /* virgl res_id → translated to gem handle     */
+   uint16_t pat_index;
+   uint16_t pad;
+   uint64_t obj_offset;  /* offset within BO (or userptr address)       */
+   uint64_t range;       /* size of the mapping in bytes                 */
+   uint64_t addr;        /* GPU virtual address                          */
+   uint32_t op;          /* DRM_XE_VM_BIND_OP_*                         */
+   uint32_t flags;       /* DRM_XE_VM_BIND_FLAG_*                       */
+};
+XE_STATIC_ASSERT_SIZE(xe_ccmd_vm_bind_op)
+
+struct xe_ccmd_vm_bind_req {
+   struct vdrm_ccmd_req hdr;
+
+   uint32_t vm_id;
+   uint32_t num_binds;
+   uint8_t  payload[];  /* num_binds × xe_ccmd_vm_bind_op               */
+};
+XE_DEFINE_CAST(vdrm_ccmd_req, xe_ccmd_vm_bind_req)
+
+struct xe_ccmd_vm_bind_rsp {
+   struct vdrm_ccmd_rsp hdr;
+
+   int32_t  ret;
+};
+XE_STATIC_ASSERT_SIZE(xe_ccmd_vm_bind_rsp)
+
+/* -------------------------------------------------------------------------
+ * XE_CCMD_EXEC_QUEUE_CREATE
+ *
+ * Creates an exec queue.  The payload carries the
+ * drm_xe_engine_class_instance array (width × num_placements entries).
+ * The host returns the kernel-assigned exec_queue_id which the guest
+ * uses verbatim in subsequent EXEC and EXEC_QUEUE_DESTROY commands.
+ * ------------------------------------------------------------------------- */
+
+struct xe_ccmd_exec_queue_create_req {
+   struct vdrm_ccmd_req hdr;
+
+   uint32_t vm_id;
+   uint16_t width;
+   uint16_t num_placements;
+   uint32_t flags;        /* DRM_XE_EXEC_QUEUE_LOW_LATENCY_HINT etc.    */
+   uint32_t pad;
+   uint8_t  payload[];    /* width × num_placements drm_xe_engine_class_instance */
+};
+XE_DEFINE_CAST(vdrm_ccmd_req, xe_ccmd_exec_queue_create_req)
+
+struct xe_ccmd_exec_queue_create_rsp {
+   struct vdrm_ccmd_rsp hdr;
+
+   uint32_t pad;
+   int32_t  ret;
+   uint32_t exec_queue_id;  /* host-assigned id; used as ring_idx too   */
+};
+XE_STATIC_ASSERT_SIZE(xe_ccmd_exec_queue_create_rsp)
+
+/* -------------------------------------------------------------------------
+ * XE_CCMD_EXEC_QUEUE_DESTROY
+ * ------------------------------------------------------------------------- */
+
+struct xe_ccmd_exec_queue_destroy_req {
+   struct vdrm_ccmd_req hdr;
+
+   uint32_t exec_queue_id;
+   uint32_t pad;
+};
+XE_DEFINE_CAST(vdrm_ccmd_req, xe_ccmd_exec_queue_destroy_req)
+
+/* -------------------------------------------------------------------------
+ * XE_CCMD_EXEC
+ *
+ * Submits a batch to the named exec queue.  The host creates an internal
+ * syncobj, adds it as the out-sync, calls DRM_IOCTL_XE_EXEC, then exports
+ * the resulting sync-fd into the drm_timeline for fence tracking.
+ *
+ * Only num_batch_buffer == 1 is supported for now (address is the GPU VA
+ * of the single batch buffer).
+ * ------------------------------------------------------------------------- */
+
+struct xe_ccmd_exec_req {
+   struct vdrm_ccmd_req hdr;
+
+   uint32_t exec_queue_id;
+   uint16_t num_batch_buffer;   /* must be 1 in current implementation  */
+   uint16_t pad;
+   uint64_t address;            /* GPU VA of batch buffer               */
+};
+XE_DEFINE_CAST(vdrm_ccmd_req, xe_ccmd_exec_req)
+
+struct xe_ccmd_exec_rsp {
+   struct vdrm_ccmd_rsp hdr;
+
+   int32_t  ret;
+};
+XE_STATIC_ASSERT_SIZE(xe_ccmd_exec_rsp)

+/* -------------------------------------------------------------------------
+ * attach_resource
+ *
+ * Called when a resource (created by another context or imported from a
+ * dmabuf) needs to be visible in this context.  We import it via
+ * drmPrimeFDToHandle so the host can use the gem handle in VM_BIND ops.
+ * ------------------------------------------------------------------------- */
+
+void
+xe_renderer_attach_resource(struct virgl_context *vctx,
+                            struct virgl_resource *res)
+{
+   struct drm_context *dctx = to_drm_context(vctx);
+   struct drm_object  *dobj =
+      drm_context_get_object_from_res_id(dctx, res->res_id);
+
+   if (dobj)
+      return;  /* already known */
+
+   int fd;
+   enum virgl_resource_fd_type fd_type = virgl_resource_export_fd(res, &fd);
+
+   if (fd_type == VIRGL_RESOURCE_FD_DMABUF) {
+      uint32_t handle;
+      int ret = drmPrimeFDToHandle(dctx->fd, fd, &handle);
+      if (ret) {
+         drm_err("drmPrimeFDToHandle failed: %s", strerror(errno));
+         close(fd);
+         return;
+      }
+
+      off_t size = lseek(fd, 0, SEEK_END);
+      close(fd);
+      if (size < 0) {
+         drm_err("lseek failed: %s", strerror(errno));
+         struct drm_gem_close close_req = { .handle = handle };
+         xe_ioctl(dctx->fd, DRM_IOCTL_GEM_CLOSE, &close_req);
+         return;
+      }
+
+      /* We don't know the original cpu_caching here; default to WB (cached). */
+      struct xe_object *obj =
+         xe_object_create(handle, (uint64_t)size, DRM_XE_GEM_CPU_CACHING_WB);
+      if (!obj) {
+         struct drm_gem_close close_req = { .handle = handle };
+         xe_ioctl(dctx->fd, DRM_IOCTL_GEM_CLOSE, &close_req);
+         return;
+      }
+
+      drm_context_object_set_res_id(dctx, &obj->base, res->res_id);
+      drm_dbg("imported dmabuf: res_id=%u handle=%u size=%zu",
+              res->res_id, handle, (size_t)size);
+   } else {
+      if (fd_type != VIRGL_RESOURCE_FD_INVALID) {
+         assert(fd_type == VIRGL_RESOURCE_OPAQUE_HANDLE ||
+                fd_type == VIRGL_RESOURCE_FD_SHM);
+         close(fd);
+      }
+   }
+}
+
+/* -------------------------------------------------------------------------
+ * export_opaque_handle
+ *
+ * Export a virgl resource as a dma-buf fd for cross-context sharing.
+ * ------------------------------------------------------------------------- */
+
+enum virgl_resource_fd_type
+xe_renderer_export_opaque_handle(struct virgl_context *vctx,
+                                 struct virgl_resource *res,
+                                 int *out_fd)
+{
+   struct drm_context *dctx = to_drm_context(vctx);
+   struct drm_object  *dobj =
+      drm_context_get_object_from_res_id(dctx, res->res_id);
+
+   drm_dbg("res_id=%u", res->res_id);
+
+   if (!dobj) {
+      drm_err("invalid res_id %u", res->res_id);
+      return VIRGL_RESOURCE_FD_INVALID;
+   }
+
+   int ret = drmPrimeHandleToFD(dctx->fd, dobj->handle,
+                                DRM_CLOEXEC | DRM_RDWR, out_fd);
+   if (ret) {
+      drm_err("drmPrimeHandleToFD failed: %s", strerror(errno));
+      return VIRGL_RESOURCE_FD_INVALID;
+   }
+
+   return VIRGL_RESOURCE_FD_DMABUF;
+}
+
+/* -------------------------------------------------------------------------
+ * get_blob
+ *
+ * Called by the VMM when the guest calls VIRTGPU_IOCTL_MAP or similar.
+ * blob_id == 0      → return the shmem control buffer.
+ * blob_id != 0      → retrieve the BO created by XE_CCMD_GEM_CREATE.
+ * ------------------------------------------------------------------------- */
+
+int
+xe_renderer_get_blob(struct virgl_context *vctx,
+                     uint32_t res_id, uint64_t blob_id,
+                     uint64_t blob_size, uint32_t blob_flags,
+                     struct virgl_context_blob *blob)
+{
+   struct drm_context *dctx = to_drm_context(vctx);
+
+   if ((blob_id >> 32) != 0) {
+      drm_err("invalid blob_id: %" PRIu64, blob_id);
+      return -EINVAL;
+   }
+
+   /* blob_id == 0 is reserved for the shmem control buffer. */
+   if (blob_id == 0)
+      return drm_context_get_shmem_blob(dctx, "xe-shmem",
+                                        sizeof(struct xe_shmem),
+                                        blob_size, blob_flags, blob);
+
+   if (!drm_context_res_id_unused(dctx, res_id)) {
+      drm_err("res_id %u already in use", res_id);
+      return -EINVAL;
+   }
+
+   struct drm_object *dobj =
+      drm_context_retrieve_object_from_blob_id(dctx, blob_id);
+   if (!dobj) {
+      drm_err("no object for blob_id %" PRIu64, blob_id);
+      return -ENOENT;
+   }
+
+   if (dobj->size != blob_size) {
+      drm_err("blob size mismatch: got %" PRIu64 " expected %" PRIu64,
+              blob_size, dobj->size);
+      return -EINVAL;
+   }
+
+   if (blob_flags & VIRGL_RENDERER_BLOB_FLAG_USE_SHAREABLE) {
+      int fd, ret;
+      ret = drmPrimeHandleToFD(dctx->fd, dobj->handle,
+                               DRM_CLOEXEC | DRM_RDWR, &fd);
+      if (ret) {
+         drm_err("drmPrimeHandleToFD failed: %s", strerror(errno));
+         return -EINVAL;
+      }
+      blob->type = VIRGL_RESOURCE_FD_DMABUF;
+      blob->u.fd = fd;
+   } else {
+      blob->type           = VIRGL_RESOURCE_OPAQUE_HANDLE;
+      blob->u.opaque_handle = dobj->handle;
+   }
+
+   struct xe_object *obj = to_xe_object(dobj);
+   blob->map_info = obj->map_info;
+
+   drm_context_object_set_res_id(dctx, dobj, res_id);
+
+   return 0;
+}

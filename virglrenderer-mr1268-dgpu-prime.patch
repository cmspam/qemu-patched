+/**
+ * struct xe_context - per-connection context for the Xe native context.
+ *
+ * Exec queues are created and destroyed dynamically; each one gets its
+ * own drm_timeline.  We use a hash table keyed on the host exec_queue_id
+ * (a small integer assigned by the kernel) to find the right timeline.
+ */
+struct xe_context {
+   struct drm_context base;
+
+   /**
+    * @exec_queue_table: maps (uint32_t exec_queue_id) → (struct drm_timeline *)
+    * Populated by XE_CCMD_EXEC_QUEUE_CREATE, drained on destroy.
+    */
+   struct hash_table *exec_queue_table;
+};
+DEFINE_CAST(drm_context, xe_context)
+
+/* -------------------------------------------------------------------------
+ * Public API
+ * ------------------------------------------------------------------------- */
+
+int xe_renderer_probe(int fd, struct virgl_renderer_capset_drm *capset);
+
+struct virgl_context *xe_renderer_create(int fd, size_t debug_len,
+                                         const char *debug_name);
+
+/* -------------------------------------------------------------------------
+ * Inline helpers
+ * ------------------------------------------------------------------------- */
+
+static inline struct drm_timeline *
+xe_context_get_timeline(struct xe_context *xctx, uint32_t exec_queue_id)
+{
+   const struct hash_entry *e =
+      hash_table_search(xctx->exec_queue_table, exec_queue_id);
+   return e ? e->data : NULL;
+}
+
+#endif /* XE_RENDERER_H_ */

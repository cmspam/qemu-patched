+/*
+ * Classify the VA driver from its vendor string.
+ * Called once during virgl_video_init().
+ */
+static enum virgl_va_driver_family virgl_video_detect_driver(const char *vendor)
+{
+    if (!vendor)
+        return VIRGL_VA_DRIVER_UNKNOWN;
+
+    if (strstr(vendor, "Mesa Gallium"))
+        return VIRGL_VA_DRIVER_MESA;
+
+    /* Intel iHD (Gen9+) and Xe driver */
+    if (strstr(vendor, "Intel iHD Driver") ||
+        strstr(vendor, "Intel i965 driver") ||
+        strstr(vendor, "Intel(R)"))
+        return VIRGL_VA_DRIVER_INTEL;
+
+    /* nvidia-vaapi-driver / VDPAU bridge */
+    if (strstr(vendor, "VDPAU") || strstr(vendor, "NVIDIA"))
+        return VIRGL_VA_DRIVER_NVIDIA;
+
+    return VIRGL_VA_DRIVER_UNKNOWN;
+}

+/*
+ * Return true if the DRM device behind fd is a virtual/software device.
+ * These cannot do real hardware VA-API decode.
+ */
+static bool virgl_drm_is_virtual(int fd)
+{
+    bool result = true;  /* Assume virtual if we can't determine */
+    drmVersionPtr ver;
+
+    if (fd < 0)
+        return true;
+
+    ver = drmGetVersion(fd);
+    if (!ver)
+        return true;
+
+    result = false;
+    for (int i = 0; virgl_virtual_drm_drivers[i]; i++) {
+        if (strcasecmp(ver->name, virgl_virtual_drm_drivers[i]) == 0) {
+            result = true;
+            break;
+        }
+    }
+
+    virgl_info("DRM device driver: %s (%s)\n", ver->name,
+               result ? "virtual" : "hardware");
+    drmFreeVersion(ver);
+    return result;
+}
+
+/*
+ * Return true if fd is an Intel GPU (i915 or xe kernel driver).
+ * Used to prefer the iHD VA driver over Mesa for correct decode behaviour.
+ */
+static bool virgl_drm_is_intel(int fd)
+{
+    bool result = false;
+    drmVersionPtr ver;
+
+    if (fd < 0)
+        return false;
+
+    ver = drmGetVersion(fd);
+    if (!ver)
+        return false;
+
+    if (strcasecmp(ver->name, "i915") == 0 ||
+        strcasecmp(ver->name, "xe") == 0)
+        result = true;
+
+    drmFreeVersion(ver);
+    return result;
+}
+
+/*
+ * Try to find a hardware DRM render node suitable for VA-API.
+ *
+ * Strategy (in order):
+ *   1. If VIRGL_VIDEO_DRM_DEVICE is set, use that path explicitly.
+ *   2. Scan /dev/dri/renderD128..191 for non-virtual devices.
+ *      For Intel GPUs, prefer iHD over Mesa by calling vaSetDriverName().
+ *
+ * Returns an open fd on success (-1 on failure).
+ * The caller owns the fd and must close it.
+ */
+static int virgl_find_hw_drm_device(void)
+{
+    const char *override = getenv("VIRGL_VIDEO_DRM_DEVICE");
+
+    if (override) {
+        int fd = open(override, O_RDWR | O_CLOEXEC);
+        if (fd >= 0) {
+            virgl_info("using VIRGL_VIDEO_DRM_DEVICE=%s\n", override);
+            return fd;
+        }
+        virgl_error("cannot open VIRGL_VIDEO_DRM_DEVICE=%s: %m\n", override);
+        return -1;
+    }
+
+    for (int i = 128; i < 192; i++) {
+        char path[32];
+        snprintf(path, sizeof(path), "/dev/dri/renderD%d", i);
+
+        int fd = open(path, O_RDWR | O_CLOEXEC);
+        if (fd < 0)
+            continue;
+
+        if (virgl_drm_is_virtual(fd)) {
+            close(fd);
+            continue;
+        }
+
+        /* Quick VA-API probe to confirm the device is usable */
+        VADisplay probe = vaGetDisplayDRM(fd);
+        if (!probe) {
+            close(fd);
+            continue;
+        }
+
+        /* For Intel GPUs, try to force iHD before probing */
+        if (virgl_drm_is_intel(fd)) {
+#if VA_CHECK_VERSION(1, 0, 0)
+            vaSetDriverName(probe, "iHD");
+#endif
+        }
+
+        int major, minor;
+        if (vaInitialize(probe, &major, &minor) == VA_STATUS_SUCCESS) {
+            const char *vendor = vaQueryVendorString(probe);
+            virgl_info("selected HW VA device %s: %s\n",
+                       path, vendor ? vendor : "<unknown>");
+            vaTerminate(probe);
+            return fd;
+        }
+
+        vaTerminate(probe);
+        close(fd);
+    }
+
+    return -1;
+}

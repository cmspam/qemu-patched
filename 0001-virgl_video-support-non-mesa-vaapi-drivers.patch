+/*
+ * Aliases for VASurfaceAttribUsageHint so callers do not need <va/va.h>.
+ * If <va/va.h> has already been included its constants are used directly.
+ */
+#ifndef VA_SURFACE_ATTRIB_USAGE_HINT_DECODER
+# define VIRGL_VA_USAGE_HINT_DECODER   0x00000001u
+# define VIRGL_VA_USAGE_HINT_ENCODER   0x00000002u
+# define VIRGL_VA_USAGE_HINT_VPP_READ  0x00000004u
+# define VIRGL_VA_USAGE_HINT_GENERIC   0x00000100u
+#else
+# define VIRGL_VA_USAGE_HINT_DECODER   VA_SURFACE_ATTRIB_USAGE_HINT_DECODER
+# define VIRGL_VA_USAGE_HINT_ENCODER   VA_SURFACE_ATTRIB_USAGE_HINT_ENCODER
+# define VIRGL_VA_USAGE_HINT_VPP_READ  VA_SURFACE_ATTRIB_USAGE_HINT_VPP_READ
+# define VIRGL_VA_USAGE_HINT_GENERIC   VA_SURFACE_ATTRIB_USAGE_HINT_GENERIC
+#endif
+
 /* flags for virgl_video_dma_buffers */
 #define VIRGL_VIDEO_DMABUF_READ_ONLY        0x0001
 #define VIRGL_VIDEO_DMABUF_WRITE_ONLY       0x0002
 #define VIRGL_VIDEO_DMABUF_READ_WRITE       0x0003
 
+/*
+ * Flags for the `flags` argument of virgl_video_init().
+ *
+ * VIRGL_VIDEO_INIT_FLAG_MESA_ONLY
+ *   Reject non-Mesa VA drivers at runtime even when the build was
+ *   compiled with -Dvaapi-all-drivers=true.
+ *
+ * VIRGL_VIDEO_INIT_FLAG_ALLOW_ALL_DRIVERS
+ *   Allow any conformant VA driver.  Only meaningful when the build was
+ *   compiled without VIRGL_VIDEO_ALLOW_ALL_VA_DRIVERS (i.e. the old
+ *   Mesa-only default).  Has no effect on an all-drivers build.
+ */
+#define VIRGL_VIDEO_INIT_FLAG_MESA_ONLY          (1u << 8)
+#define VIRGL_VIDEO_INIT_FLAG_ALLOW_ALL_DRIVERS  (1u << 9)
+
 struct virgl_video_dma_buf {
     struct virgl_video_buffer *buf;
 

--- a/src/vrend/virgl_video.c
+++ b/src/vrend/virgl_video.c
@@ -88,6 +88,28 @@
 #define CODED_BUF_DEFAULT_SIZE(width, height) \
     ((width) * (height) / (16 * 16) * 512)
 
+/*
+ * Driver family, detected once in virgl_video_init() from the VA vendor string.
+ */
+enum virgl_va_driver_family {
+    VIRGL_VA_DRIVER_MESA    = 0,   /* Mesa Gallium (radeonsi, nouveau, …)       */
+    VIRGL_VA_DRIVER_INTEL,         /* Intel iHD Driver for Intel Gen / Xe       */
+    VIRGL_VA_DRIVER_NVIDIA,        /* nvidia-vaapi-driver / VDPAU bridge        */
+    VIRGL_VA_DRIVER_UNKNOWN,       /* Any other conformant libva back-end        */
+};
+
+static enum virgl_va_driver_family va_driver_family = VIRGL_VA_DRIVER_UNKNOWN;
+
+/*
+ * Encode entrypoint capabilities probed at init time.
+ *   VA_ENC_CAP_ENCSLICE    – VAEntrypointEncSlice   is available
+ *   VA_ENC_CAP_ENCSLICE_LP – VAEntrypointEncSliceLP is available
+ */
+#define VA_ENC_CAP_ENCSLICE    (1u << 0)
+#define VA_ENC_CAP_ENCSLICE_LP (1u << 1)
+
+static unsigned va_encode_caps = 0;
+
 struct virgl_video_buffer {
     enum pipe_format format;
     uint32_t width;
@@ -109,6 +131,7 @@
    uint32_t max_references;
    VAContextID va_ctx;
    VAConfigID  va_cfg;
+   int         va_entrypoint;               /* actual VA entrypoint chosen (may differ from pipe) */
    struct virgl_video_buffer *buffer;
    struct virgl_video_buffer *ref_pic_list[32]; /* Enc: reference pictures */
    VABufferID  va_coded_buf;                    /* Enc: VACodedBuffer */
@@ -166,7 +189,11 @@
    }
 }
 
-/* NOTE: mesa va frontend only supports VLD and EncSlice */
+/*
+ * Both VAEntrypointEncSlice (full-rate) and VAEntrypointEncSliceLP (low-power)
+ * map to PIPE_VIDEO_ENTRYPOINT_ENCODE.  The actual entrypoint to use is chosen
+ * in va_entrypoint_from_pipe() based on driver capability probing.
+ */
 static enum pipe_video_entrypoint pipe_entrypoint_from_va(
         VAEntrypoint entrypoint)
 {
@@ -282,12 +309,38 @@
     case PIPE_VIDEO_ENTRYPOINT_MC:
         return VAEntrypointMoComp;
     case PIPE_VIDEO_ENTRYPOINT_ENCODE:
+        /*
+         * Intel iHD / xe driver exposes encode through VAEntrypointEncSliceLP
+         * (low-power path).  For other drivers prefer VAEntrypointEncSlice.
+         * virgl_video_create_codec() will fall back automatically if the
+         * primary choice isn't supported for a specific profile.
+         */
+        if (va_driver_family == VIRGL_VA_DRIVER_INTEL &&
+            (va_encode_caps & VA_ENC_CAP_ENCSLICE_LP))
+            return VAEntrypointEncSliceLP;
         return VAEntrypointEncSlice;
     default:
         return VAEntrypointNone;
     }
 }
 
+/*
+ * Return the alternate encode entrypoint to try if the primary one fails.
+ * Returns VAEntrypointNone when no alternative is available.
+ */
+static int va_encode_entrypoint_fallback(int primary)
+{
+    if (primary == VAEntrypointEncSlice &&
+        (va_encode_caps & VA_ENC_CAP_ENCSLICE_LP))
+        return VAEntrypointEncSliceLP;
+
+    if (primary == VAEntrypointEncSliceLP &&
+        (va_encode_caps & VA_ENC_CAP_ENCSLICE))
+        return VAEntrypointEncSlice;
+
+    return VAEntrypointNone;
+}
+
 static uint32_t va_format_from_pipe(uint32_t format)
 {
     uint32_t va_format;

     idx = frame_num % ARRAY_SIZE(codec->ref_pic_list);
 
     if (!codec->ref_pic_list[idx]) {
-        args.format = PIPE_FORMAT_NV21;
+        /*
+         * NV21 is not supported by Intel iHD / xe driver.  Use NV12 which
+         * is the universal baseline YUV 4:2:0 format for reference frames.
+         */
+        args.format = PIPE_FORMAT_NV12;
         args.width = codec->width;
         args.height = codec->height;
         args.interlaced = 0;
@@ -541,6 +598,75 @@
     return codec->ref_pic_list[idx]->va_sfc;
 }
 
+/*
+ * Classify the VA driver from its vendor string.
+ * Called once during virgl_video_init().
+ */
+static enum virgl_va_driver_family virgl_video_detect_driver(const char *vendor)
+{
+    if (!vendor)
+        return VIRGL_VA_DRIVER_UNKNOWN;
+
+    if (strstr(vendor, "Mesa Gallium"))
+        return VIRGL_VA_DRIVER_MESA;
+
+    /*
+     * Intel iHD (Gen9+) and Xe driver:
+     *   "Intel iHD Driver for Intel(R) Gen Graphics - <ver>"
+     * Intel legacy i965:
+     *   "Intel i965 driver for Intel(R) <platform> - <ver>"
+     */
+    if (strstr(vendor, "Intel iHD Driver") ||
+        strstr(vendor, "Intel i965 driver") ||
+        strstr(vendor, "Intel(R)"))
+        return VIRGL_VA_DRIVER_INTEL;
+
+    /*
+     * nvidia-vaapi-driver (ruinland / elFarto):
+     *   "Splitted-Desktop Systems VDPAU backend for VA-API - <ver>"
+     * Some builds report "NVIDIA" directly.
+     */
+    if (strstr(vendor, "VDPAU") || strstr(vendor, "NVIDIA"))
+        return VIRGL_VA_DRIVER_NVIDIA;
+
+    return VIRGL_VA_DRIVER_UNKNOWN;
+}
+
+/*
+ * Probe which encode entrypoints the driver actually exposes.
+ * Uses H.264 High as the reference profile – every HW encoder supports it.
+ * Populates va_encode_caps.
+ */
+static void virgl_video_probe_encode_caps(void)
+{
+    VAEntrypoint *eps;
+    int n, max_eps;
+
+    va_encode_caps = 0;
+    max_eps = vaMaxNumEntrypoints(va_dpy);
+    if (max_eps <= 0)
+        return;
+
+    eps = calloc(max_eps, sizeof(*eps));
+    if (!eps)
+        return;
+
+    if (vaQueryConfigEntrypoints(va_dpy, VAProfileH264High,
+                                 eps, &n) == VA_STATUS_SUCCESS) {
+        for (int i = 0; i < n; i++) {
+            if (eps[i] == VAEntrypointEncSlice)
+                va_encode_caps |= VA_ENC_CAP_ENCSLICE;
+            if (eps[i] == VAEntrypointEncSliceLP)
+                va_encode_caps |= VA_ENC_CAP_ENCSLICE_LP;
+        }
+    }
+
+    free(eps);
+    virgl_info("VA encode caps: EncSlice=%d EncSliceLP=%d\n",
+               !!(va_encode_caps & VA_ENC_CAP_ENCSLICE),
+               !!(va_encode_caps & VA_ENC_CAP_ENCSLICE_LP));
+}
+
 int virgl_video_init(int drm_fd,
                      struct virgl_video_callbacks *cbs, unsigned int flags)
 {
@@ -548,8 +674,6 @@

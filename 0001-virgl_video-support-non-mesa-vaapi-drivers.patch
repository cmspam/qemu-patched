--- a/src/vrend/virgl_video.h
+++ b/src/vrend/virgl_video.h
@@ -72,14 +72,51 @@
     uint32_t width;
     uint32_t height;
     bool interlaced;
+    /*
+     * VA surface usage hint – set to one of the VIRGL_VA_USAGE_HINT_* values

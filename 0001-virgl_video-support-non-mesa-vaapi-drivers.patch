-    if (!driver || !strstr(driver, "Mesa Gallium")) {
-        virgl_error("only supports mesa va drivers now\n");
+    va_driver_family = virgl_video_detect_driver(driver);
+
+#if !defined(VIRGL_VIDEO_ALLOW_ALL_VA_DRIVERS)
+    /*
+     * Built with the original Mesa-only restriction.  The caller can lift
+     * it at runtime with VIRGL_VIDEO_INIT_FLAG_ALLOW_ALL_DRIVERS, or the
+     * build can be configured with -Dvaapi-all-drivers=true.
+     */
+    if (!(flags & VIRGL_VIDEO_INIT_FLAG_ALLOW_ALL_DRIVERS) &&
+        va_driver_family != VIRGL_VA_DRIVER_MESA) {
+        virgl_error("only supports mesa va drivers (build restriction); "
+                    "rebuild with -Dvaapi-all-drivers=true to enable "
+                    "Intel/NVIDIA support\n");
         virgl_video_destroy();
         return -1;
     }
+#else
+    /*
+     * All-drivers build.  Still honour an explicit Mesa-only flag so that
+     * a host administrator can restrict the capability at runtime if needed.
+     */
+    if ((flags & VIRGL_VIDEO_INIT_FLAG_MESA_ONLY) &&
+        va_driver_family != VIRGL_VA_DRIVER_MESA) {
+        virgl_error("only supports mesa va drivers (runtime flag)\n");
+        virgl_video_destroy();
+        return -1;
+    }
+    (void)flags;
+#endif
 
-    callbacks = cbs;
+    switch (va_driver_family) {
+    case VIRGL_VA_DRIVER_MESA:
+        virgl_info("VA driver family: Mesa Gallium\n");
+        break;
+    case VIRGL_VA_DRIVER_INTEL:
+        virgl_info("VA driver family: Intel (iHD / Xe)\n");
+        break;
+    case VIRGL_VA_DRIVER_NVIDIA:
+        virgl_info("VA driver family: NVIDIA (VDPAU bridge)\n");
+        break;
+    default:
+        virgl_info("VA driver family: unknown – proceeding with standard VA-API\n");
+        break;
+    }
 
+    virgl_video_probe_encode_caps();
+    callbacks = cbs;
     return 0;
 }
 

     }
 
-    callbacks = cbs;
+    switch (va_driver_family) {
+    case VIRGL_VA_DRIVER_MESA:
+        virgl_info("VA driver family: Mesa Gallium\n"); break;
+    case VIRGL_VA_DRIVER_INTEL:
+        virgl_info("VA driver family: Intel (iHD / Xe)\n"); break;
+    case VIRGL_VA_DRIVER_NVIDIA:
+        virgl_info("VA driver family: NVIDIA (VDPAU bridge)\n"); break;
+    default:
+        virgl_info("VA driver family: unknown\n"); break;
+    }
 
+    virgl_video_probe_encode_caps();
+    callbacks = cbs;
     return 0;

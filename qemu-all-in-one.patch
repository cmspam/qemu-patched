+static void virgl_cmd_resource_assign_uuid(VirtIOGPU *g,
+                                           struct virtio_gpu_ctrl_command *cmd)
+{
+    struct virtio_gpu_resource_assign_uuid assign;
+    struct virtio_gpu_resp_resource_uuid resp;
+    struct virtio_gpu_simple_resource *res;
+    QemuUUID uuid;
+
+    VIRTIO_GPU_FILL_CMD(assign);
+    trace_virtio_gpu_cmd_res_assign_uuid(assign.resource_id);
+
+    if (!virtio_gpu_resource_uuid_enabled(g->parent_obj.conf)) {
+        qemu_log_mask(LOG_GUEST_ERROR,
+                      "%s: resource uuid feature not negotiated\n", __func__);
+        cmd->error = VIRTIO_GPU_RESP_ERR_INVALID_PARAMETER;
+        return;
+    }
+
+    res = virtio_gpu_find_resource(g, assign.resource_id);
+    if (!res) {
+        qemu_log_mask(LOG_GUEST_ERROR, "%s: resource 0x%x not found\n",
+                      __func__, assign.resource_id);
+        cmd->error = VIRTIO_GPU_RESP_ERR_INVALID_RESOURCE_ID;
+        return;
+    }
+
+    memset(&resp, 0, sizeof(resp));
+    resp.hdr.type = VIRTIO_GPU_RESP_OK_RESOURCE_UUID;
+    qemu_uuid_generate(&uuid);
+
+    if (res->dmabuf_fd >= 0) {
+        if (!virtio_add_dmabuf(&uuid, res->dmabuf_fd)) {
+            qemu_log_mask(LOG_GUEST_ERROR,
+                          "%s: failed to register dmabuf for resource 0x%x\n",
+                          __func__, assign.resource_id);
+        }
+    }
+
+    memcpy(resp.uuid, &uuid, sizeof(uuid));
+    virtio_gpu_ctrl_response(g, cmd, &resp.hdr, sizeof(resp));
+}

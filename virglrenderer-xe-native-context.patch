diff --git a/src/drm/xe/xe_ccmd.c b/src/drm/xe/xe_ccmd.c
new file mode 100644
index 00000000..107cb3cf
--- /dev/null
+++ b/src/drm/xe/xe_ccmd.c
@@ -0,0 +1,450 @@
+/*
+ * Copyright 2025 Google LLC
+ * SPDX-License-Identifier: MIT
+ */
+
+#include "virgl_fence.h"
+
+#include "util/hash_table.h"
+#include "util/u_atomic.h"
+
+#pragma GCC diagnostic push
+#if !defined(__clang__) && defined(__GNUC__)
+#pragma GCC diagnostic ignored "-Wpedantic"
+#else
+#pragma GCC diagnostic ignored "-Wzero-length-array"
+#endif
+#include "drm-uapi/xe_drm.h"
+#pragma GCC diagnostic pop
+
+#include "xe_ccmd.h"
+#include "xe_object.h"
+#include "xe_resource.h"
+
+/*
+ * XE_CCMD_DEVICE_QUERY
+ */
+static int
+xe_ccmd_device_query(struct drm_context *dctx, struct vdrm_ccmd_req *hdr)
+{
+   const struct xe_ccmd_device_query_req *req =
+      to_xe_ccmd_device_query_req(hdr);
+
+   uint32_t payload_sz = req->size;
+   size_t rsp_sz = size_add(sizeof(struct xe_ccmd_device_query_rsp),
+                            ((size_t)(payload_sz) + 7u) & ~(size_t)7u);
+
+   struct xe_ccmd_device_query_rsp *rsp =
+      drm_context_rsp(dctx, hdr, rsp_sz);
+   if (!rsp)
+      return -ENOMEM;
+
+   struct drm_xe_device_query query = {
+      .query = req->query,
+      .size  = payload_sz,
+      .data  = payload_sz ? (uintptr_t)rsp->payload : 0,
+   };
+
+   rsp->ret  = drmIoctl(dctx->fd, DRM_IOCTL_XE_DEVICE_QUERY, &query) ? errno : 0;
+   rsp->size = query.size;
+
+   return 0;
+}
+
+/*
+ * XE_CCMD_GEM_CREATE
+ */
+static int
+xe_ccmd_gem_create(struct drm_context *dctx, struct vdrm_ccmd_req *hdr)
+{
+   const struct xe_ccmd_gem_create_req *req = to_xe_ccmd_gem_create_req(hdr);
+
+   if (!drm_context_blob_id_valid(dctx, req->blob_id)) {
+      drm_err("invalid blob_id %u", req->blob_id);
+      return -EINVAL;
+   }
+
+   struct drm_xe_gem_create create = {
+      .size        = req->size,
+      .placement   = req->placement,
+      .flags       = req->flags,
+      .vm_id       = 0,  /* must be 0: vm_id != 0 makes the BO non-exportable */
+      .cpu_caching = req->cpu_caching,
+   };
+
+   int ret = drmIoctl(dctx->fd, DRM_IOCTL_XE_GEM_CREATE, &create);
+   if (ret)
+      return -errno;
+
+   struct xe_object *obj =
+      xe_object_create(create.handle, create.size, req->cpu_caching);
+   if (!obj) {
+      struct drm_gem_close close = { .handle = create.handle };
+      drmIoctl(dctx->fd, DRM_IOCTL_GEM_CLOSE, &close);
+      return -ENOMEM;
+   }
+
+   drm_context_object_set_blob_id(dctx, &obj->base, req->blob_id);
+
+   return 0;
+}
+
+/*
+ * XE_CCMD_VM_CREATE
+ */
+static int
+xe_ccmd_vm_create(struct drm_context *dctx, struct vdrm_ccmd_req *hdr)
+{
+   const struct xe_ccmd_vm_create_req *req = to_xe_ccmd_vm_create_req(hdr);
+
+   struct xe_ccmd_vm_create_rsp *rsp =
+      drm_context_rsp(dctx, hdr, sizeof(*rsp));
+   if (!rsp)
+      return -ENOMEM;
+
+   struct drm_xe_vm_create create = {
+      .flags = req->flags,
+   };
+
+   rsp->ret   = drmIoctl(dctx->fd, DRM_IOCTL_XE_VM_CREATE, &create) ? errno : 0;
+   rsp->vm_id = create.vm_id;
+
+   return 0;
+}
+
+/*
+ * XE_CCMD_VM_DESTROY
+ */
+static int
+xe_ccmd_vm_destroy(struct drm_context *dctx, struct vdrm_ccmd_req *hdr)
+{
+   const struct xe_ccmd_vm_destroy_req *req = to_xe_ccmd_vm_destroy_req(hdr);
+
+   struct drm_xe_vm_destroy destroy = {
+      .vm_id = req->vm_id,
+   };
+
+   drmIoctl(dctx->fd, DRM_IOCTL_XE_VM_DESTROY, &destroy);
+
+   return 0;
+}
+
+/*
+ * XE_CCMD_VM_BIND
+ *
+ * Translates guest res_ids to host GEM handles and issues a synchronous
+ * DRM_IOCTL_XE_VM_BIND.
+ */
+static int
+xe_ccmd_vm_bind(struct drm_context *dctx, struct vdrm_ccmd_req *hdr)
+{
+   const struct xe_ccmd_vm_bind_req *req = to_xe_ccmd_vm_bind_req(hdr);
+
+   size_t ops_sz = size_mul(sizeof(struct xe_ccmd_vm_bind_op), req->num_binds);
+   size_t expected_len = size_add(sizeof(*req), ops_sz);
+
+   if (hdr->len != expected_len) {
+      drm_err("bad len: %u vs %zu", hdr->len, expected_len);
+      return -EINVAL;
+   }
+
+   if (req->num_binds == 0)
+      return 0;
+
+   struct xe_ccmd_vm_bind_rsp *rsp =
+      drm_context_rsp(dctx, hdr, sizeof(*rsp));
+   if (!rsp)
+      return -ENOMEM;
+
+   const struct xe_ccmd_vm_bind_op *guest_ops =
+      (const struct xe_ccmd_vm_bind_op *)req->payload;
+
+   struct drm_xe_vm_bind_op *host_ops =
+      malloc(size_mul(sizeof(*host_ops), req->num_binds));
+   if (!host_ops) {
+      rsp->ret = ENOMEM;
+      return 0;
+   }
+
+   for (uint32_t i = 0; i < req->num_binds; i++) {
+      const struct xe_ccmd_vm_bind_op *gop = &guest_ops[i];
+      struct drm_xe_vm_bind_op *hop = &host_ops[i];
+
+      memset(hop, 0, sizeof(*hop));
+      hop->pat_index  = gop->pat_index;
+      hop->obj_offset = gop->obj_offset;
+      hop->range      = gop->range;
+      hop->addr       = gop->addr;
+      hop->op         = gop->op;
+      hop->flags      = gop->flags;
+
+      if (gop->op == DRM_XE_VM_BIND_OP_MAP ||
+          gop->op == DRM_XE_VM_BIND_OP_UNMAP_ALL) {
+         if (gop->res_id != 0) {
+            struct drm_object *dobj =
+               drm_context_get_object_from_res_id(dctx, gop->res_id);
+            if (!dobj) {
+               drm_err("invalid res_id %u in bind op %u", gop->res_id, i);
+               rsp->ret = EINVAL;
+               free(host_ops);
+               return 0;
+            }
+            hop->obj = dobj->handle;
+         } else {
+            /* NULL mapping (DRM_XE_VM_BIND_FLAG_NULL) */
+            hop->obj = 0;
+         }
+      }
+   }
+
+   struct drm_xe_vm_bind args = {
+      .vm_id      = req->vm_id,
+      .num_binds  = req->num_binds,
+      .num_syncs  = 0,
+      .syncs      = 0,
+   };
+
+   if (req->num_binds == 1) {
+      args.bind = host_ops[0];
+   } else {
+      args.vector_of_binds = (uintptr_t)host_ops;
+   }
+
+   rsp->ret = drmIoctl(dctx->fd, DRM_IOCTL_XE_VM_BIND, &args) ? errno : 0;
+
+   free(host_ops);
+   return 0;
+}
+
+/*
+ * XE_CCMD_EXEC_QUEUE_CREATE
+ */
+static int
+xe_ccmd_exec_queue_create(struct drm_context *dctx, struct vdrm_ccmd_req *hdr)
+{
+   struct xe_context *xctx = to_xe_context(dctx);
+   const struct xe_ccmd_exec_queue_create_req *req =
+      to_xe_ccmd_exec_queue_create_req(hdr);
+
+   uint32_t n_instances = (uint32_t)req->width * req->num_placements;
+   size_t instances_sz =
+      size_mul(sizeof(struct drm_xe_engine_class_instance), n_instances);
+   size_t expected_len = size_add(sizeof(*req), instances_sz);
+
+   if (hdr->len != expected_len) {
+      drm_err("bad len: %u vs %zu", hdr->len, expected_len);
+      return -EINVAL;
+   }
+
+   struct xe_ccmd_exec_queue_create_rsp *rsp =
+      drm_context_rsp(dctx, hdr, sizeof(*rsp));
+   if (!rsp)
+      return -ENOMEM;
+
+   struct drm_xe_exec_queue_create create = {
+      .width           = req->width,
+      .num_placements  = req->num_placements,
+      .vm_id           = req->vm_id,
+      .flags           = req->flags,
+      .instances       = (uintptr_t)req->payload,
+   };
+
+   rsp->ret = drmIoctl(dctx->fd, DRM_IOCTL_XE_EXEC_QUEUE_CREATE, &create) ? errno : 0;
+   if (rsp->ret) {
+      rsp->exec_queue_id = 0;
+      return 0;
+   }
+
+   rsp->exec_queue_id = create.exec_queue_id;
+
+   /* Create per-queue data: timeline + persistent syncobj. */
+   struct xe_exec_queue_data *eq = calloc(1, sizeof(*eq));
+   if (!eq) {
+      struct drm_xe_exec_queue_destroy destroy = {
+         .exec_queue_id = create.exec_queue_id,
+      };
+      drmIoctl(dctx->fd, DRM_IOCTL_XE_EXEC_QUEUE_DESTROY, &destroy);
+      rsp->ret = ENOMEM;
+      rsp->exec_queue_id = 0;
+      return 0;
+   }
+
+   drm_timeline_init(&eq->timeline, &dctx->base, "xe-exec-queue",
+                     create.exec_queue_id, drm_context_fence_retire);
+
+   struct drm_syncobj_create sc = { .flags = 0 };
+   if (drmIoctl(dctx->fd, DRM_IOCTL_SYNCOBJ_CREATE, &sc)) {
+      drm_timeline_fini(&eq->timeline);
+      free(eq);
+      struct drm_xe_exec_queue_destroy destroy = {
+         .exec_queue_id = create.exec_queue_id,
+      };
+      drmIoctl(dctx->fd, DRM_IOCTL_XE_EXEC_QUEUE_DESTROY, &destroy);
+      rsp->ret = ENOMEM;
+      rsp->exec_queue_id = 0;
+      return 0;
+   }
+   eq->out_syncobj = sc.handle;
+
+   _mesa_hash_table_insert(xctx->exec_queue_table,
+                           (void *)(uintptr_t)(create.exec_queue_id + 1), eq);
+
+   return 0;
+}
+
+/*
+ * XE_CCMD_EXEC_QUEUE_DESTROY
+ */
+static int
+xe_ccmd_exec_queue_destroy(struct drm_context *dctx, struct vdrm_ccmd_req *hdr)
+{
+   struct xe_context *xctx = to_xe_context(dctx);
+   const struct xe_ccmd_exec_queue_destroy_req *req =
+      to_xe_ccmd_exec_queue_destroy_req(hdr);
+
+   /* Tear down the timeline before destroying the kernel queue so that any
+    * in-flight fence wait threads can drain cleanly.
+    */
+   struct hash_entry *entry =
+      hash_table_search(xctx->exec_queue_table, req->exec_queue_id + 1);
+   if (entry) {
+      struct xe_exec_queue_data *eq = entry->data;
+      drm_timeline_fini(&eq->timeline);
+      if (eq->out_syncobj) {
+         struct drm_syncobj_destroy sd = { .handle = eq->out_syncobj };
+         drmIoctl(dctx->fd, DRM_IOCTL_SYNCOBJ_DESTROY, &sd);
+      }
+      free(eq);
+      _mesa_hash_table_remove(xctx->exec_queue_table, entry);
+   }
+
+   struct drm_xe_exec_queue_destroy destroy = {
+      .exec_queue_id = req->exec_queue_id,
+   };
+
+   drmIoctl(dctx->fd, DRM_IOCTL_XE_EXEC_QUEUE_DESTROY, &destroy);
+
+   return 0;
+}
+
+/*
+ * XE_CCMD_EXEC
+ *
+ * Resets the persistent per-queue syncobj, submits the batch, then
+ * exports the resulting sync-fd and hands it to drm_timeline for
+ * virgl fence tracking.
+ */
+static int
+xe_ccmd_exec(struct drm_context *dctx, struct vdrm_ccmd_req *hdr)
+{
+   struct xe_context *xctx = to_xe_context(dctx);
+   const struct xe_ccmd_exec_req *req = to_xe_ccmd_exec_req(hdr);
+
+   struct xe_ccmd_exec_rsp *rsp =
+      drm_context_rsp(dctx, hdr, sizeof(*rsp));
+   if (!rsp)
+      return -ENOMEM;
+
+   struct xe_exec_queue_data *eq =
+      xe_context_get_queue_data(xctx, req->exec_queue_id);
+   if (!eq) {
+      drm_err("unknown exec_queue_id %u", req->exec_queue_id);
+      rsp->ret = EINVAL;
+      return 0;
+   }
+
+   /*
+    * Build the syncs array:
+    *   [0] optional: in-fence (imported from virgl fence fd)
+    *   [1] required: out-sync (persistent syncobj -> sync_fd -> timeline)
+    */
+   struct drm_xe_sync syncs[2];
+   uint32_t num_syncs = 0;
+   uint32_t in_syncobj = 0;
+
+   int in_fence_fd = virgl_context_take_in_fence_fd(&dctx->base);
+   if (in_fence_fd >= 0) {
+      struct drm_syncobj_handle sh = {
+         .fd    = in_fence_fd,
+         .flags = DRM_SYNCOBJ_FD_TO_HANDLE_FLAGS_IMPORT_SYNC_FILE,
+      };
+      if (drmIoctl(dctx->fd, DRM_IOCTL_SYNCOBJ_FD_TO_HANDLE, &sh) == 0) {
+         in_syncobj = sh.handle;
+         syncs[num_syncs++] = (struct drm_xe_sync){
+            .type   = DRM_XE_SYNC_TYPE_SYNCOBJ,
+            .flags  = 0,  /* wait */
+            .handle = in_syncobj,
+         };
+      }
+      close(in_fence_fd);
+   }
+
+   /* Reset persistent syncobj before reuse. */
+   {
+      struct drm_syncobj_array arr = {
+         .handles = (uintptr_t)&eq->out_syncobj,
+         .count_handles = 1,
+      };
+      drmIoctl(dctx->fd, DRM_IOCTL_SYNCOBJ_RESET, &arr);
+   }
+
+   syncs[num_syncs++] = (struct drm_xe_sync){
+      .type   = DRM_XE_SYNC_TYPE_SYNCOBJ,
+      .flags  = DRM_XE_SYNC_FLAG_SIGNAL,
+      .handle = eq->out_syncobj,
+   };
+
+   struct drm_xe_exec exec = {
+      .exec_queue_id    = req->exec_queue_id,
+      .num_syncs        = num_syncs,
+      .syncs            = (uintptr_t)syncs,
+      .address          = req->address,
+      .num_batch_buffer = req->num_batch_buffer,
+   };
+
+   rsp->ret = drmIoctl(dctx->fd, DRM_IOCTL_XE_EXEC, &exec) ? errno : 0;
+
+   if (!rsp->ret) {
+      struct drm_syncobj_handle sh = {
+         .handle = eq->out_syncobj,
+         .flags  = DRM_SYNCOBJ_HANDLE_TO_FD_FLAGS_EXPORT_SYNC_FILE,
+      };
+      if (drmIoctl(dctx->fd, DRM_IOCTL_SYNCOBJ_HANDLE_TO_FD, &sh) == 0)
+         drm_timeline_set_last_fence_fd(&eq->timeline, sh.fd);
+   }
+
+   if (rsp->ret == EIO) {
+      struct xe_shmem *shmem = to_xe_shmem(dctx->shmem);
+      if (shmem && req->exec_queue_id < 64) {
+         p_atomic_set(&shmem->banned_exec_queue_mask,
+                      shmem->banned_exec_queue_mask |
+                      (1ULL << req->exec_queue_id));
+      }
+   }
+
+   if (in_syncobj) {
+      struct drm_syncobj_destroy sd = { .handle = in_syncobj };
+      drmIoctl(dctx->fd, DRM_IOCTL_SYNCOBJ_DESTROY, &sd);
+   }
+
+   return 0;
+}
+
+/*
+ * Dispatch table
+ */
+const struct drm_ccmd xe_ccmd_dispatch[] = {
+#define HANDLER(N, n) \
+   [XE_CCMD_##N] = {#N, xe_ccmd_##n, sizeof(struct xe_ccmd_##n##_req)}
+   HANDLER(DEVICE_QUERY,        device_query),
+   HANDLER(GEM_CREATE,          gem_create),
+   HANDLER(VM_CREATE,           vm_create),
+   HANDLER(VM_DESTROY,          vm_destroy),
+   HANDLER(VM_BIND,             vm_bind),
+   HANDLER(EXEC_QUEUE_CREATE,   exec_queue_create),
+   HANDLER(EXEC_QUEUE_DESTROY,  exec_queue_destroy),
+   HANDLER(EXEC,                exec),
+#undef HANDLER
+};
+
+const unsigned int xe_ccmd_dispatch_size = ARRAY_SIZE(xe_ccmd_dispatch);

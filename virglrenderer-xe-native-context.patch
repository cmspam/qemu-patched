diff --git a/src/drm/xe/xe_proto.h b/src/drm/xe/xe_proto.h
new file mode 100644
index 00000000..32df8293
--- /dev/null
+++ b/src/drm/xe/xe_proto.h
@@ -0,0 +1,212 @@
+/*
+ * Copyright 2025 Google LLC
+ * SPDX-License-Identifier: MIT
+ */
+
+#ifndef XE_VIRTIO_PROTO_H_
+#define XE_VIRTIO_PROTO_H_
+
+#ifdef __GNUC__
+# pragma GCC diagnostic push
+# pragma GCC diagnostic error "-Wpadded"
+#endif
+
+#define XE_STATIC_ASSERT_SIZE(t)                                              \
+   static_assert(sizeof(struct t) % 8 == 0,                                  \
+                 "sizeof(struct " #t ") not multiple of 8");                  \
+   static_assert(alignof(struct t) <= 8,                                      \
+                 "alignof(struct " #t ") too large");
+
+#define XE_DEFINE_CAST(parent, child)                                         \
+   XE_STATIC_ASSERT_SIZE(child)                                               \
+   DEFINE_CAST(parent, child)
+
+enum xe_ccmd {
+   XE_CCMD_NOP              = 0,
+   XE_CCMD_DEVICE_QUERY     = 1,
+   XE_CCMD_GEM_CREATE       = 2,
+   XE_CCMD_VM_CREATE        = 3,
+   XE_CCMD_VM_DESTROY       = 4,
+   XE_CCMD_VM_BIND          = 5,
+   XE_CCMD_EXEC_QUEUE_CREATE  = 6,
+   XE_CCMD_EXEC_QUEUE_DESTROY = 7,
+   XE_CCMD_EXEC             = 8,
+};
+
+#define XE_CCMD(_cmd, _len) (struct vdrm_ccmd_req){    \
+       .cmd = XE_CCMD_##_cmd,                          \
+       .len = (_len),                                  \
+   }
+
+/**
+ * Defines the layout of shmem buffer used for host->guest communication.
+ */
+struct xe_shmem {
+   struct vdrm_shmem base;
+
+   /**
+    * Bitmask of banned exec queue IDs.
+    */
+   uint64_t banned_exec_queue_mask;
+};
+DEFINE_CAST(vdrm_shmem, xe_shmem)
+
+/*
+ * XE_CCMD_DEVICE_QUERY
+ */
+struct xe_ccmd_device_query_req {
+   struct vdrm_ccmd_req hdr;
+
+   uint32_t query;   /* DRM_XE_DEVICE_QUERY_* */
+   uint32_t size;    /* requested payload size (0 = probe) */
+};
+XE_DEFINE_CAST(vdrm_ccmd_req, xe_ccmd_device_query_req)
+
+struct xe_ccmd_device_query_rsp {
+   struct vdrm_ccmd_rsp hdr;
+
+   uint32_t pad;
+   int32_t  ret;
+   uint32_t size;
+   uint8_t  payload[];
+};
+XE_STATIC_ASSERT_SIZE(xe_ccmd_device_query_rsp)
+
+/*
+ * XE_CCMD_GEM_CREATE
+ */
+struct xe_ccmd_gem_create_req {
+   struct vdrm_ccmd_req hdr;
+
+   uint64_t size;
+   uint32_t placement;
+   uint32_t flags;
+   uint32_t vm_id;
+   uint32_t blob_id;
+   uint16_t cpu_caching;
+   uint16_t pad[3];
+};
+XE_DEFINE_CAST(vdrm_ccmd_req, xe_ccmd_gem_create_req)
+
+/*
+ * XE_CCMD_VM_CREATE
+ */
+struct xe_ccmd_vm_create_req {
+   struct vdrm_ccmd_req hdr;
+
+   uint32_t flags;
+   uint32_t pad;
+};
+XE_DEFINE_CAST(vdrm_ccmd_req, xe_ccmd_vm_create_req)
+
+struct xe_ccmd_vm_create_rsp {
+   struct vdrm_ccmd_rsp hdr;
+
+   uint32_t pad;
+   int32_t  ret;
+   uint32_t vm_id;
+};
+XE_STATIC_ASSERT_SIZE(xe_ccmd_vm_create_rsp)
+
+/*
+ * XE_CCMD_VM_DESTROY
+ */
+struct xe_ccmd_vm_destroy_req {
+   struct vdrm_ccmd_req hdr;
+
+   uint32_t vm_id;
+   uint32_t pad;
+};
+XE_DEFINE_CAST(vdrm_ccmd_req, xe_ccmd_vm_destroy_req)
+
+/*
+ * XE_CCMD_VM_BIND
+ */
+struct xe_ccmd_vm_bind_op {
+   uint32_t res_id;
+   uint16_t pat_index;
+   uint16_t pad;
+   uint64_t obj_offset;
+   uint64_t range;
+   uint64_t addr;
+   uint32_t op;
+   uint32_t flags;
+};
+XE_STATIC_ASSERT_SIZE(xe_ccmd_vm_bind_op)
+
+struct xe_ccmd_vm_bind_req {
+   struct vdrm_ccmd_req hdr;
+
+   uint32_t vm_id;
+   uint32_t num_binds;
+   uint8_t  payload[];
+};
+XE_DEFINE_CAST(vdrm_ccmd_req, xe_ccmd_vm_bind_req)
+
+struct xe_ccmd_vm_bind_rsp {
+   struct vdrm_ccmd_rsp hdr;
+
+   int32_t  ret;
+};
+XE_STATIC_ASSERT_SIZE(xe_ccmd_vm_bind_rsp)
+
+/*
+ * XE_CCMD_EXEC_QUEUE_CREATE
+ */
+struct xe_ccmd_exec_queue_create_req {
+   struct vdrm_ccmd_req hdr;
+
+   uint32_t vm_id;
+   uint16_t width;
+   uint16_t num_placements;
+   uint32_t flags;
+   uint32_t pad;
+   uint8_t  payload[];
+};
+XE_DEFINE_CAST(vdrm_ccmd_req, xe_ccmd_exec_queue_create_req)
+
+struct xe_ccmd_exec_queue_create_rsp {
+   struct vdrm_ccmd_rsp hdr;
+
+   uint32_t pad;
+   int32_t  ret;
+   uint32_t exec_queue_id;
+};
+XE_STATIC_ASSERT_SIZE(xe_ccmd_exec_queue_create_rsp)
+
+/*
+ * XE_CCMD_EXEC_QUEUE_DESTROY
+ */
+struct xe_ccmd_exec_queue_destroy_req {
+   struct vdrm_ccmd_req hdr;
+
+   uint32_t exec_queue_id;
+   uint32_t pad;
+};
+XE_DEFINE_CAST(vdrm_ccmd_req, xe_ccmd_exec_queue_destroy_req)
+
+/*
+ * XE_CCMD_EXEC
+ */
+struct xe_ccmd_exec_req {
+   struct vdrm_ccmd_req hdr;
+
+   uint32_t exec_queue_id;
+   uint16_t num_batch_buffer;
+   uint16_t pad;
+   uint64_t address;
+};
+XE_DEFINE_CAST(vdrm_ccmd_req, xe_ccmd_exec_req)
+
+struct xe_ccmd_exec_rsp {
+   struct vdrm_ccmd_rsp hdr;
+
+   int32_t  ret;
+};
+XE_STATIC_ASSERT_SIZE(xe_ccmd_exec_rsp)
+
+#ifdef __GNUC__
+# pragma GCC diagnostic pop
+#endif
+
+#endif /* XE_VIRTIO_PROTO_H_ */
diff --git a/src/drm/xe/xe_renderer.c b/src/drm/xe/xe_renderer.c
new file mode 100644
index 00000000..2d42b71a
--- /dev/null
+++ b/src/drm/xe/xe_renderer.c
@@ -0,0 +1,133 @@
+/*
+ * Copyright 2025 Google LLC
+ * SPDX-License-Identifier: MIT
+ */
+
+#include "virglrenderer.h"
+
+#include "util/hash_table.h"
+
+#include "xe_ccmd.h"
+#include "xe_object.h"
+#include "xe_resource.h"
+#include "xe_renderer.h"
+
+/**
+ * Probe capset params.
+ */
+int
+xe_renderer_probe(int fd, struct virgl_renderer_capset_drm *capset)
+{
+   drmDevicePtr drmdev = NULL;
+
+   if (drmGetDevice2(fd, DRM_DEVICE_GET_PCI_REVISION, &drmdev)) {
+      drm_dbg("failed to query drm device: %d", -errno);
+      return -EINVAL;
+   }
+
+   capset->u.xe.pci_bus         = drmdev->businfo.pci->bus;
+   capset->u.xe.pci_dev         = drmdev->businfo.pci->dev;
+   capset->u.xe.pci_func        = drmdev->businfo.pci->func;
+   capset->u.xe.pci_domain      = drmdev->businfo.pci->domain;
+   capset->u.xe.pci_device_id   = drmdev->deviceinfo.pci->device_id;
+   capset->u.xe.pci_revision_id = drmdev->deviceinfo.pci->revision_id;
+
+   capset->wire_format_version = 1;
+
+   drm_dbg("wire_format_version: %u", capset->wire_format_version);
+   drm_dbg("version_major:       %u", capset->version_major);
+   drm_dbg("version_minor:       %u", capset->version_minor);
+   drm_dbg("version_patchlevel:  %u", capset->version_patchlevel);
+   drm_dbg("pci_bus:             %u", capset->u.xe.pci_bus);
+   drm_dbg("pci_dev:             %u", capset->u.xe.pci_dev);
+   drm_dbg("pci_func:            %u", capset->u.xe.pci_func);
+   drm_dbg("pci_domain:          %u", capset->u.xe.pci_domain);
+   drm_dbg("pci_device_id:       %u", capset->u.xe.pci_device_id);
+   drm_dbg("pci_revision_id:     %u", capset->u.xe.pci_revision_id);
+
+   drmFreeDevice(&drmdev);
+
+   return 0;
+}
+
+static void
+xe_queue_data_free_cb(UNUSED const void *key, void *data, void *arg)
+{
+   struct xe_exec_queue_data *eq = data;
+   int fd = (int)(intptr_t)arg;
+
+   drm_timeline_fini(&eq->timeline);
+   if (eq->out_syncobj) {
+      struct drm_syncobj_destroy sd = { .handle = eq->out_syncobj };
+      drmIoctl(fd, DRM_IOCTL_SYNCOBJ_DESTROY, &sd);
+   }
+   free(eq);
+}
+
+static void
+xe_renderer_destroy(struct virgl_context *vctx)
+{
+   struct drm_context *dctx = to_drm_context(vctx);
+   struct xe_context  *xctx = to_xe_context(dctx);
+
+   hash_table_call_foreach(xctx->exec_queue_table,
+                           xe_queue_data_free_cb,
+                           (void *)(intptr_t)dctx->fd);
+   _mesa_hash_table_destroy(xctx->exec_queue_table, NULL);
+
+   drm_context_deinit(dctx);
+   free(xctx);
+}
+
+static int
+xe_renderer_submit_fence(struct virgl_context *vctx, uint32_t flags,
+                         uint32_t queue_id, uint64_t fence_id)
+{
+   struct drm_context *dctx = to_drm_context(vctx);
+   struct xe_context  *xctx = to_xe_context(dctx);
+
+   struct xe_exec_queue_data *eq =
+      xe_context_get_queue_data(xctx, queue_id);
+
+   if (!eq || eq->timeline.last_fence_fd < 0) {
+      vctx->fence_retire(vctx, queue_id, fence_id);
+      return 0;
+   }
+
+   return drm_timeline_submit_fence(&eq->timeline, flags, fence_id);
+}
+
+struct virgl_context *
+xe_renderer_create(int fd, UNUSED size_t debug_len,
+                   UNUSED const char *debug_name)
+{
+   struct xe_context *xctx;
+
+   xctx = calloc(1, sizeof(*xctx));
+   if (!xctx)
+      return NULL;
+
+   if (!drm_context_init(&xctx->base, fd,
+                         xe_ccmd_dispatch, xe_ccmd_dispatch_size)) {
+      free(xctx);
+      return NULL;
+   }
+
+   xctx->exec_queue_table = _mesa_hash_table_create_u32_keys(NULL);
+   if (!xctx->exec_queue_table) {
+      drm_context_deinit(&xctx->base);
+      free(xctx);
+      return NULL;
+   }
+
+   xctx->base.base.destroy              = xe_renderer_destroy;
+   xctx->base.base.attach_resource      = xe_renderer_attach_resource;
+   xctx->base.base.export_opaque_handle = xe_renderer_export_opaque_handle;
+   xctx->base.base.get_blob             = xe_renderer_get_blob;
+   xctx->base.base.submit_fence         = xe_renderer_submit_fence;
+   xctx->base.base.supports_fence_sharing = true;
+   xctx->base.free_object               = xe_renderer_free_object;
+   xctx->base.ccmd_alignment            = 8;
+
+   return &xctx->base.base;
+}
diff --git a/src/drm/xe/xe_renderer.h b/src/drm/xe/xe_renderer.h
new file mode 100644
index 00000000..0c857098
--- /dev/null
+++ b/src/drm/xe/xe_renderer.h
@@ -0,0 +1,77 @@
+/*
+ * Copyright 2025 Google LLC
+ * SPDX-License-Identifier: MIT
+ */
+
+#ifndef XE_RENDERER_H_
+#define XE_RENDERER_H_
+
+#include "config.h"
+
+#include <errno.h>
+#include <fcntl.h>
+#include <inttypes.h>
+#include <stddef.h>
+#include <stdint.h>
+#include <stdlib.h>
+#include <string.h>
+#include <time.h>
+#include <unistd.h>
+#include <sys/mman.h>
+#include <sys/types.h>
+
+#include <xf86drm.h>
+
+#include "virgl_context.h"
+#include "virgl_util.h"
+
+#include "drm_context.h"
+#include "drm_fence.h"
+#include "drm_util.h"
+#include "drm_hw.h"
+
+#include "util/hash_table.h"
+#include "xe_proto.h"
+
+/**
+ * Per-exec-queue data: timeline for fence tracking + persistent syncobj
+ * to avoid create/destroy per exec call.
+ */
+struct xe_exec_queue_data {
+   struct drm_timeline timeline;
+   uint32_t out_syncobj;    /* reused across execs -- reset before each use */
+};
+
+struct xe_context {
+   struct drm_context base;
+
+   /**
+    * @exec_queue_table: maps (exec_queue_id + 1) -> (struct xe_exec_queue_data *)
+    *
+    * Populated by XE_CCMD_EXEC_QUEUE_CREATE, drained on destroy.
+    * Keys are offset by +1 because hash_table_search() treats 0 as empty.
+    */
+   struct hash_table *exec_queue_table;
+};
+DEFINE_CAST(drm_context, xe_context)
+
+int xe_renderer_probe(int fd, struct virgl_renderer_capset_drm *capset);
+
+struct virgl_context *xe_renderer_create(int fd, size_t debug_len,
+                                         const char *debug_name);
+
+/**
+ * Look up per-queue data by exec_queue_id.
+ *
+ * Keys are stored as (exec_queue_id + 1) because the u32-key hash table
+ * treats key == 0 as "entry not present".
+ */
+static inline struct xe_exec_queue_data *
+xe_context_get_queue_data(struct xe_context *xctx, uint32_t exec_queue_id)
+{
+   struct hash_entry *e =
+      hash_table_search(xctx->exec_queue_table, exec_queue_id + 1);
+   return e ? e->data : NULL;
+}
+
+#endif /* XE_RENDERER_H_ */
diff --git a/src/drm/xe/xe_resource.c b/src/drm/xe/xe_resource.c
new file mode 100644
index 00000000..9b10e9ae
--- /dev/null
+++ b/src/drm/xe/xe_resource.c
@@ -0,0 +1,166 @@
+/*
+ * Copyright 2025 Google LLC
+ * SPDX-License-Identifier: MIT
+ */
+
+#include "util/anon_file.h"
+
+#pragma GCC diagnostic push
+#if !defined(__clang__) && defined(__GNUC__)
+#pragma GCC diagnostic ignored "-Wpedantic"
+#else
+#pragma GCC diagnostic ignored "-Wzero-length-array"
+#endif
+#include "drm-uapi/xe_drm.h"
+#pragma GCC diagnostic pop
+
+#include "xe_object.h"
+#include "xe_resource.h"
+
+static int
+gem_close(int fd, uint32_t handle)
+{
+   struct drm_gem_close close_req = {
+      .handle = handle,
+   };
+   return drmIoctl(fd, DRM_IOCTL_GEM_CLOSE, &close_req);
+}
+
+void
+xe_renderer_attach_resource(struct virgl_context *vctx,
+                            struct virgl_resource *res)
+{
+   struct drm_context *dctx = to_drm_context(vctx);
+   struct drm_object *dobj = drm_context_get_object_from_res_id(dctx, res->res_id);
+
+   if (dobj)
+      return;
+
+   int fd;
+   enum virgl_resource_fd_type fd_type = virgl_resource_export_fd(res, &fd);
+
+   if (fd_type == VIRGL_RESOURCE_FD_DMABUF) {
+      uint32_t handle;
+      int ret;
+
+      ret = drmPrimeFDToHandle(dctx->fd, fd, &handle);
+      if (ret) {
+         drm_err("Could not import: %s", strerror(errno));
+         close(fd);
+         return;
+      }
+
+      off_t size = lseek(fd, 0, SEEK_END);
+      close(fd);
+      if (size < 0) {
+         drm_err("lseek failed: %" PRId64 " (%s)", size, strerror(errno));
+         gem_close(dctx->fd, handle);
+         return;
+      }
+
+      /* Imported BOs: default to WB since we don't know the original caching. */
+      struct xe_object *obj =
+         xe_object_create(handle, (uint64_t)size, DRM_XE_GEM_CPU_CACHING_WB);
+      if (!obj) {
+         gem_close(dctx->fd, handle);
+         return;
+      }
+
+      drm_context_object_set_res_id(dctx, &obj->base, res->res_id);
+
+      drm_dbg("obj=%p, res_id=%u, handle=%u", (void *)obj,
+              obj->base.res_id, obj->base.handle);
+   } else {
+      if (fd_type != VIRGL_RESOURCE_FD_INVALID) {
+         assert(fd_type == VIRGL_RESOURCE_OPAQUE_HANDLE ||
+                fd_type == VIRGL_RESOURCE_FD_SHM);
+         close(fd);
+      }
+   }
+}
+
+enum virgl_resource_fd_type
+xe_renderer_export_opaque_handle(struct virgl_context *vctx,
+                                 struct virgl_resource *res,
+                                 int *out_fd)
+{
+   struct drm_context *dctx = to_drm_context(vctx);
+   struct drm_object *dobj = drm_context_get_object_from_res_id(dctx, res->res_id);
+   int ret;
+
+   drm_dbg("obj=%p, res_id=%u", (void *)dobj, res->res_id);
+
+   if (!dobj) {
+      drm_err("invalid res_id %u", res->res_id);
+      return VIRGL_RESOURCE_FD_INVALID;
+   }
+
+   ret = drmPrimeHandleToFD(dctx->fd, dobj->handle, DRM_CLOEXEC | DRM_RDWR, out_fd);
+   if (ret) {
+      drm_err("failed to get dmabuf fd: %s", strerror(errno));
+      return VIRGL_RESOURCE_FD_INVALID;
+   }
+
+   return VIRGL_RESOURCE_FD_DMABUF;
+}
+
+int
+xe_renderer_get_blob(struct virgl_context *vctx, uint32_t res_id, uint64_t blob_id,
+                     uint64_t blob_size, uint32_t blob_flags,
+                     struct virgl_context_blob *blob)
+{
+   struct drm_context *dctx = to_drm_context(vctx);
+
+   if ((blob_id >> 32) != 0) {
+      drm_err("invalid blob_id: %" PRIu64, blob_id);
+      return -EINVAL;
+   }
+
+   /* blob_id of zero is reserved for the shmem buffer: */
+   if (blob_id == 0)
+      return drm_context_get_shmem_blob(dctx, "xe-shmem",
+                                        sizeof(struct xe_shmem),
+                                        blob_size, blob_flags, blob);
+
+   if (!drm_context_res_id_unused(dctx, res_id)) {
+      drm_err("res_id %u already in use", res_id);
+      return -EINVAL;
+   }
+
+   struct drm_object *dobj =
+      drm_context_retrieve_object_from_blob_id(dctx, blob_id);
+
+   /* If GEM_CREATE fails, we can end up here without a backing obj: */
+   if (!dobj) {
+      drm_err("no object");
+      return -ENOENT;
+   }
+
+   if (dobj->size != blob_size) {
+      drm_err("Invalid blob size");
+      return -EINVAL;
+   }
+
+   if (blob_flags & VIRGL_RENDERER_BLOB_FLAG_USE_SHAREABLE) {
+      int fd, ret;
+
+      ret = drmPrimeHandleToFD(dctx->fd, dobj->handle, DRM_CLOEXEC | DRM_RDWR, &fd);
+      if (ret) {
+         drm_err("export to fd failed");
+         return -EINVAL;
+      }
+
+      blob->type = VIRGL_RESOURCE_FD_DMABUF;
+      blob->u.fd = fd;
+   } else {
+      blob->type = VIRGL_RESOURCE_OPAQUE_HANDLE;
+      blob->u.opaque_handle = dobj->handle;
+   }
+
+   struct xe_object *obj = to_xe_object(dobj);
+   blob->map_info = obj->map_info;
+
+   drm_context_object_set_res_id(dctx, dobj, res_id);
+
+   return 0;
+}
